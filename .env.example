# VisionPIP Demo — Environment Configuration
# Copy this file to .env.local before running the demo:
#   cp .env.example .env.local
# The start-demo.sh script does this automatically.

# Mock Supabase (auto-configured by start-demo.sh)
NEXT_PUBLIC_SUPABASE_URL="http://localhost:3000/api/mock-supabase"
SUPABASE_URL="http://localhost:3000/api/mock-supabase"

# Supabase Keys (placeholder — mock client only)
NEXT_PUBLIC_SUPABASE_ANON_KEY="demo-anon-key-placeholder"
SUPABASE_SERVICE_ROLE_KEY="demo-service-role-key-placeholder"

# Gemini AI (required for AI Lease-Bot)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Admin Secret
ADMIN_SECRET=vision-demo-secret
